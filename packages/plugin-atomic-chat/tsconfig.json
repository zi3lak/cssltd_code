{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["node"]
  },
  "include": ["src/**/*", "test/**/*"]
}
