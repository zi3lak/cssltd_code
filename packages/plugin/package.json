    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "devDependencies": {
    "@opentui/core": "catalog:",
    "@opentui/solid": "catalog:",
    "@tsconfig/node22": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@opentui/keymap": "catalog:"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cssltd-Org/cssltdcode",
    "directory": "packages/plugin"
  }
