{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@cssltdcode/plugin",
  "version": "7.4.11",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "build": "tsc"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tool": "./src/tool.ts",
    "./tui": "./src/tui.ts"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@cssltdcode/sdk": "workspace:*",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.3.4",
    "@opentui/solid": ">=0.3.4",
    "@opentui/keymap": ">=0.3.4"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
