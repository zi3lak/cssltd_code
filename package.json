{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "cssltd_code",
  "description": "CSSLTD Code — internal AI coding tool for CSSLTD engineers (paid provider APIs + local Ollama models)",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bun run --cwd packages/cssltdcode --conditions=browser src/index.ts",
    "dev:local": "bun run packages/cssltdcode/script/dev-local.ts",
    "lint": "oxlint",
    "typecheck": "bun turbo typecheck",
    "upgrade-opentui": "bun run script/upgrade-opentui.ts",
    "postinstall": "bun run --cwd packages/core fix-node-pty && bun run script/setup-git.ts",
    "test": "echo 'do not run tests from root' && exit 1",
    "dev-setup": "bun run --cwd packages/cssltdcode --conditions=browser src/index.ts dev-setup"
  },
  "workspaces": {
